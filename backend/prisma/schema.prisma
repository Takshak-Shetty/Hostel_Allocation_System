generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id              Int          @id @default(autoincrement())
  name            String
  branch          String
  year            Int
  gender          String
  disciplineScore Int?
  preferences     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  email           String       @unique
  password        String
  allocations     Allocation[]
  complaints      Complaint[]
}

model Hostel {
  id            Int         @id @default(autoincrement())
  name          String
  genderAllowed String
  capacity      Int
  distance      Int
  createdAt     DateTime    @default(now())
  complaints    Complaint[]
  rooms         Room[]
}

model Room {
  id               Int          @id @default(autoincrement())
  hostelId         Int
  roomNumber       String
  capacity         Int
  currentOccupancy Int          @default(0)
  createdAt        DateTime     @default(now())
  allocations      Allocation[]
  complaints       Complaint[]
  hostel           Hostel       @relation(fields: [hostelId], references: [id])

  @@unique([hostelId, roomNumber])
}

model Allocation {
  id          Int      @id @default(autoincrement())
  allocatedAt DateTime @default(now())
  studentId   Int
  roomId      Int
  active      Boolean  @default(true)
  room        Room     @relation(fields: [roomId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([roomId])
  @@index([studentId])
}

model Complaint {
  id          Int      @id @default(autoincrement())
  issueType   String
  description String?
  severity    Severity
  status      Status   @default(PENDING)
  createdAt   DateTime @default(now())
  studentId   Int
  hostelId    Int
  roomId      Int?
  category    String?
  updatedAt   DateTime @updatedAt
  hostel      Hostel   @relation(fields: [hostelId], references: [id])
  room        Room?    @relation(fields: [roomId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([hostelId], map: "Complaint_hostelId_fkey")
  @@index([roomId], map: "Complaint_roomId_fkey")
  @@index([studentId], map: "Complaint_studentId_fkey")
}

model Admin {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      Admin_role @default(WARDEN)
  createdAt DateTime   @default(now())
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  PENDING
  IN_PROGRESS
  RESOLVED
  ESCALATED
  CLOSED
}

enum Admin_role {
  SUPERADMIN
  WARDEN
  MAINTENANCE
  AGENT
}
